        }
      ]
    },
    "typography": {
      "fontFamilies": [
        {
          "fontFamily": "'Inter', sans-serif",
          "name": "Основной текст",
          "slug": "primary"
        },
        {
          "fontFamily": "'Space Grotesk', sans-serif",
          "name": "Заголовки",
          "slug": "heading"
        }
      ],
      "fontSizes": [
        { "slug": "small", "size": "0.875rem", "name": "Мелкий" },
        { "slug": "medium", "size": "1rem", "name": "Основной" },
        { "slug": "large", "size": "1.25rem", "name": "Крупный" },
        { "slug": "x-large", "size": "2rem", "name": "H2" },
        { "slug": "xx-large", "size": "3rem", "name": "H1" },
        { "slug": "xxx-large", "size": "3.75rem", "name": "Гигантский" }
      ]
    },
    "layout": {
      "contentSize": "900px",
      "wideSize": "1200px"
    },
    "spacing": {
      "units": ["px", "em", "rem", "%", "vw", "vh"],
      "blockGap": true,
      "margin": true,
      "padding": true
    },
    "border": {
      "radius": true,
      "style": true,
      "width": true
    }
  },
  "styles": {
    "color": {
      "background": "var(--wp--preset--color--light)",
      "text": "var(--wp--preset--color--dark)"
    },
    "typography": {
      "fontFamily": "var(--wp--preset--font-family--primary)",
      "lineHeight": "1.6"
    },
    "blocks": {
      "core/button": {
        "border": {
          "radius": "100px"
        },
        "color": {
          "background": "var(--wp--preset--color--primary)",
          "text": "var(--wp--preset--color--white)"
        },
        "typography": {
          "fontWeight": "600",
          "textTransform": "uppercase",
          "letterSpacing": "0.5px"
        }
      },
      "core/heading": {
        "typography": {
          "fontFamily": "var(--wp--preset--font-family--heading)",
          "fontWeight": "700",
          "lineHeight": "1.2"
        }
      }
    },
    "elements": {
      "h1": {
        "typography": {
          "fontSize": "var(--wp--preset--font-size--xxx-large)"
        }
      },
      "h2": {
        "typography": {
          "fontSize": "var(--wp--preset--font-size--xx-large)"
        }
      },
      "link": {
        "color": {
          "text": "var(--wp--preset--color--primary)"
        }
      }
    }
  },
  "templateParts": [
    {
      "name": "header",
      "title": "Шапка AI-сервиса",
      "area": "header"
    },
    {
      "name": "footer",
      "title": "Подвал AI-сервиса",
      "area": "footer"
    }
  ]
